{
  "manifest_version": 3,
  "name": "P6 Seller Page Catche",
  "version": "3.1",
  "description": "Verificação rápida de ASINs e vitrines de sellers no Seller Central",
  "permissions": ["activeTab", "storage", "downloads"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.amazon.com.br/*",
        "*://www.amazon.com/*",
        "*://amazon.com.br/*",
        "*://amazon.com/*",
        "*://sellercentral.amazon.com.br/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
